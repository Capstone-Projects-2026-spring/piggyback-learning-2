{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "desktop",
  "version": "0.1.0",
  "identifier": "com.piggyback.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Piggyback Learning",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/yt-dlp", "binaries/ffmpeg"],
    "resources": {
      "models/vosk-lgraph-model/**/*": "models/vosk-lgraph-model/",
      "models/mood/emotion-ferplus-8.onnx": "models/mood/emotion-ferplus-8.onnx",
      "lib/libvosk.so": "lib/libvosk.so",
      "lib/libvosk.dylib": "lib/libvosk.dylib",
      "lib/libvosk.dll": "lib/libvosk.dll",
      "lib/vosk_api.h": "lib/vosk_api.h"
    }
  }
}
